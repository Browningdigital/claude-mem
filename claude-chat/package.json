{
  "name": "claude-chat",
  "version": "1.0.0",
  "type": "module",
  "bin": "dist/server.js",
  "scripts": {
    "dev": "NO_OPEN=1 tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc",
    "icon": "node build-icon.mjs",
    "pkg": "npm run build && npm run icon && npx @yao-pkg/pkg dist/server.js --targets node22-win-x64 --output claude-chat.exe --assets public/**/*",
    "patch-exe": "node scripts/patch-exe.mjs claude-chat.exe icon.ico",
    "dist": "npm run pkg && npm run patch-exe"
  },
  "pkg": {
    "assets": ["public/**/*", "node_modules/@hono/node-server/**/*"],
    "outputPath": "."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/node-ws": "^1.3.0",
    "@types/node": "^25.3.2",
    "@types/ws": "^8.18.1",
    "hono": "^4.12.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ws": "^8.19.0"
  }
}
