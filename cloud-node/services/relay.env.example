# Browning Cloud Node — Chat Relay Environment
# Copy to /home/agent/.config/relay.env and fill in values.
#
# RELAY_AUTH_TOKEN is auto-generated during cloud-init.
# See ~/node-status.json for the generated token.
# WARNING: If RELAY_AUTH_TOKEN is empty, the relay server is OPEN to anyone!

RELAY_PORT=3000
RELAY_AUTH_TOKEN=<generated during cloud-init, see ~/node-status.json>
WORKSPACE_DIR=/home/agent/workspace
CLAUDE_MEM_REPO=/home/agent/claude-mem
SUPABASE_URL=https://wcdyvukzlxxkgvxomaxr.supabase.co
SUPABASE_KEY=<service_role_key>
MAX_CONCURRENT=3
SESSION_MAX_AGE_DAYS=30
