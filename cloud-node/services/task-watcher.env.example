# Browning Cloud Node — Task Watcher Environment
# Copy to /home/agent/.config/task-watcher.env and fill in values.
#
# Get credentials from Browning Memory MCP or Supabase Management API.

# ── Supabase REST API (for task queue CRUD) ──
SUPABASE_URL=https://wcdyvukzlxxkgvxomaxr.supabase.co
SUPABASE_KEY=<service_role_key from Browning Memory>

# ── Supabase Management API (for SQL queries — sessions, credentials, events) ──
SUPABASE_ADMIN_API=https://api.supabase.com/v1/projects/wcdyvukzlxxkgvxomaxr/database/query
SUPABASE_ADMIN_TOKEN=<management_api_token from Browning Memory>

# ── Task execution ──
WORKSPACE_DIR=/home/agent/workspace
CLAUDE_MEM_REPO=/home/agent/claude-mem
POLL_INTERVAL=5
MAX_CONCURRENT=2
